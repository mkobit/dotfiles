load("@bazel_skylib//rules:diff_test.bzl", "diff_test")
load("@rules_shell//shell:sh_binary.bzl", "sh_binary")
load("@rules_shell//shell:sh_test.bzl", "sh_test")

sh_test(
    name = "rulesync_test",
    srcs = ["rulesync_test.sh"],
    args = ["$(rootpath @multitool//tools/rulesync)"],
    data = ["@multitool//tools/rulesync"],
)

# Rulesync source files
filegroup(
    name = "rulesync_sources",
    srcs = [
        "//:.rulesync/rules/00-preferences.md",
        "//:.rulesync/rules/01-agents-md.md",
        "//:.rulesync/rules/02-no-auto-commit.md",
        "//:.rulesync/rules/10-technical-writing.md",
        "//:.rulesync/rules/11-write-agent-context.md",
        "//:rulesync.jsonc",
    ],
    visibility = ["//visibility:public"],
)

# Generate configuration files for all AI tools from unified rules
genrule(
    name = "generate",
    srcs = [
        "//:.rulesync/rules/00-preferences.md",
        "//:.rulesync/rules/01-agents-md.md",
        "//:.rulesync/rules/02-no-auto-commit.md",
        "//:.rulesync/rules/10-technical-writing.md",
        "//:.rulesync/rules/11-write-agent-context.md",
        "//:rulesync.jsonc",
    ],
    outs = [
        "out/CLAUDE.md",
        "out/.claude/rules/01-agents-md.md",
        "out/.claude/rules/02-no-auto-commit.md",
        "out/.claude/rules/10-technical-writing.md",
        "out/.claude/rules/11-write-agent-context.md",
        "out/GEMINI.md",
        "out/.gemini/memories/01-agents-md.md",
        "out/.gemini/memories/02-no-auto-commit.md",
        "out/.gemini/memories/10-technical-writing.md",
        "out/.gemini/memories/11-write-agent-context.md",
        "out/.cursor/rules/00-preferences.mdc",
        "out/.cursor/rules/01-agents-md.mdc",
        "out/.cursor/rules/02-no-auto-commit.mdc",
        "out/.cursor/rules/10-technical-writing.mdc",
        "out/.cursor/rules/11-write-agent-context.mdc",
    ],
    cmd = """
        RULESYNC="$$PWD/$(execpath @multitool//tools/rulesync)"
        OUTDIR=$$(dirname $(location out/CLAUDE.md))

        # Set up workspace structure for rulesync
        mkdir -p "$$OUTDIR/.rulesync/rules"
        cp $(location //:rulesync.jsonc) "$$OUTDIR/rulesync.jsonc"
        cp $(location //:.rulesync/rules/00-preferences.md) "$$OUTDIR/.rulesync/rules/00-preferences.md"
        cp $(location //:.rulesync/rules/01-agents-md.md) "$$OUTDIR/.rulesync/rules/01-agents-md.md"
        cp $(location //:.rulesync/rules/02-no-auto-commit.md) "$$OUTDIR/.rulesync/rules/02-no-auto-commit.md"
        cp $(location //:.rulesync/rules/10-technical-writing.md) "$$OUTDIR/.rulesync/rules/10-technical-writing.md"
        cp $(location //:.rulesync/rules/11-write-agent-context.md) "$$OUTDIR/.rulesync/rules/11-write-agent-context.md"

        # Run rulesync generate
        cd "$$OUTDIR" && "$$RULESYNC" generate --silent
    """,
    tools = ["@multitool//tools/rulesync"],
    visibility = ["//visibility:public"],
)

# Drift check: verify checked-in outputs match fresh generation.
# Run with: bazel run //tools/rulesync:check
# BUILD_WORKSPACE_DIRECTORY is set by `bazel run`.
sh_binary(
    name = "check",
    srcs = ["rulesync_drift_test.sh"],
    args = ["$(rootpath @multitool//tools/rulesync)"],
    data = [
        "@multitool//tools/rulesync",
    ],
)

# Drift tests: compare genrule outputs against committed files.
# Maps each generated output to the corresponding committed file at the repo root.
_DRIFT_PAIRS = {
    "out/CLAUDE.md": "//:CLAUDE.md",
    "out/.claude/rules/01-agents-md.md": "//.claude:rules/01-agents-md.md",
    "out/.claude/rules/02-no-auto-commit.md": "//.claude:rules/02-no-auto-commit.md",
    "out/.claude/rules/10-technical-writing.md": "//.claude:rules/10-technical-writing.md",
    "out/.claude/rules/11-write-agent-context.md": "//.claude:rules/11-write-agent-context.md",
    "out/GEMINI.md": "//:GEMINI.md",
    "out/.gemini/memories/01-agents-md.md": "//:.gemini/memories/01-agents-md.md",
    "out/.gemini/memories/02-no-auto-commit.md": "//:.gemini/memories/02-no-auto-commit.md",
    "out/.gemini/memories/10-technical-writing.md": "//:.gemini/memories/10-technical-writing.md",
    "out/.gemini/memories/11-write-agent-context.md": "//:.gemini/memories/11-write-agent-context.md",
    "out/.cursor/rules/00-preferences.mdc": "//:.cursor/rules/00-preferences.mdc",
    "out/.cursor/rules/01-agents-md.mdc": "//:.cursor/rules/01-agents-md.mdc",
    "out/.cursor/rules/02-no-auto-commit.mdc": "//:.cursor/rules/02-no-auto-commit.mdc",
    "out/.cursor/rules/10-technical-writing.mdc": "//:.cursor/rules/10-technical-writing.mdc",
    "out/.cursor/rules/11-write-agent-context.mdc": "//:.cursor/rules/11-write-agent-context.mdc",
}

[
    diff_test(
        name = "drift_" + generated.replace("out/", "").replace("/", "_").replace(".", "_"),
        file1 = generated,
        file2 = committed,
    )
    for generated, committed in _DRIFT_PAIRS.items()
]

test_suite(
    name = "drift_tests",
    tests = [
        ":drift_" + generated.replace("out/", "").replace("/", "_").replace(".", "_")
        for generated in _DRIFT_PAIRS.keys()
    ],
)
