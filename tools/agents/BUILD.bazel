# Aliases for backward-compatible target names.
# The actual py_binary targets live in //tools/agents/skills_cli.

# Sync portable skills: bazel run //tools/agents:sync
alias(
    name = "sync",
    actual = "//tools/agents/skills_cli:sync",
)

# Drift check: bazel run //tools/agents:check
alias(
    name = "check",
    actual = "//tools/agents/skills_cli:check",
)

# Validate all canonical skills: bazel run //tools/agents:validate
alias(
    name = "validate",
    actual = "//tools/agents/skills_cli:validate",
)
