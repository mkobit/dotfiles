load("@pypi//:requirements.bzl", "requirement")
load("@rules_python//python:defs.bzl", "py_binary", "py_library", "py_test")

# Export dir_diff.py for use as a py_test source in drift test macros.
# Export validate_test_runner.py for use in validation test macros.
exports_files(
    [
        "dir_diff.py",
        "validate_test_runner.py",
    ],
    visibility = ["//src/agents/skills:__pkg__"],
)

py_library(
    name = "skills_cli_lib",
    srcs = [
        "core.py",
        "frontmatter.py",
        "models.py",
        "validate.py",
        "validate_models.py",
    ],
    visibility = [
        "//src/agents/skills:__pkg__",
        "//tools/agents:__pkg__",
    ],
    deps = [
        requirement("pydantic"),
        requirement("pyyaml"),
    ],
)

# Sync portable skills from canonical source to chezmoi tool directories.
# Run with: bazel run //tools/agents:sync
py_binary(
    name = "sync",
    srcs = ["sync_cmd.py"],
    data = ["@anthropic_skills//:skill_creator_files"],
    main = "sync_cmd.py",
    visibility = ["//tools/agents:__pkg__"],
    deps = [
        ":skills_cli_lib",
        requirement("click"),
    ],
)

# Drift check: verify committed skill copies match canonical source.
# Run with: bazel run //tools/agents:check
py_binary(
    name = "check",
    srcs = ["check_cmd.py"],
    data = ["@anthropic_skills//:skill_creator_files"],
    main = "check_cmd.py",
    visibility = ["//tools/agents:__pkg__"],
    deps = [
        ":skills_cli_lib",
        requirement("click"),
    ],
)

# Validate all canonical skills interactively.
# Run with: bazel run //tools/agents:validate
py_binary(
    name = "validate",
    srcs = ["validate_cmd.py"],
    main = "validate_cmd.py",
    visibility = ["//tools/agents:__pkg__"],
    deps = [
        ":skills_cli_lib",
        requirement("click"),
    ],
)

# Directory-level drift test script (used by py_test targets in rules.bzl).
py_binary(
    name = "dir_diff_test_bin",
    srcs = ["dir_diff.py"],
    main = "dir_diff.py",
    visibility = ["//src/agents/skills:__pkg__"],
    deps = [":skills_cli_lib"],
)

py_test(
    name = "skills_cli_test",
    srcs = ["test_core.py"],
    main = "test_core.py",
    deps = [
        ":skills_cli_lib",
        requirement("pytest"),
    ],
)

py_test(
    name = "test_validate",
    srcs = ["test_validate.py"],
    main = "test_validate.py",
    deps = [
        ":skills_cli_lib",
        requirement("pytest"),
    ],
)
