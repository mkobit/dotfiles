# Python tooling rules for building and deploying CLI tools

package(default_visibility = ["//visibility:public"])

# Direct alias to the binary distributed in the ty wheel.
# This avoids the overhead and complexity of a py_binary wrapper
# while still respecting the version in requirements.lock.txt.
alias(
    name = "ty",
    actual = "@@rules_python++pip+pypi_314_ty//:bin/ty",
)
