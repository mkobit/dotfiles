load("@bazel_skylib//:bzl_library.bzl", "bzl_library")
load("@rules_python//python:defs.bzl", "py_binary", "py_library", "py_test")

bzl_library(
    name = "defs",
    srcs = ["defs.bzl"],
    visibility = ["//visibility:public"],
    deps = [
        "//tools/agentskills/private:collection",
        "//tools/agentskills/private:gemini",
        "//tools/agentskills/private:skill",
        "@tar.bzl//tar",
        "@tar.bzl//tar:mtree",
    ],
)

bzl_library(
    name = "extensions",
    srcs = ["extensions.bzl"],
    visibility = ["//visibility:public"],
)

py_library(
    name = "models",
    srcs = ["models.py"],
    visibility = ["//visibility:public"],
    deps = [
        "@pypi//pydantic",
    ],
)

py_binary(
    name = "process_skill",
    srcs = ["process_skill.py"],
    visibility = ["//visibility:public"],
    deps = [
        ":models",
        "@pypi//click",
        "@pypi//pydantic",
        "@pypi//python_frontmatter",
    ],
)

py_binary(
    name = "transform_skill",
    srcs = ["transform_skill.py"],
    visibility = ["//visibility:public"],
    deps = [
        ":process_skill",
        "@pypi//click",
        "@pypi//pydantic",
        "@pypi//pyyaml",
        "@pypi//types_pyyaml",
    ],
)

py_binary(
    name = "process_agent",
    srcs = ["process_agent.py"],
    visibility = ["//visibility:public"],
    deps = [
        ":models",
        "@pypi//click",
        "@pypi//pydantic",
        "@pypi//python_frontmatter",
    ],
)

py_test(
    name = "process_skill_test",
    srcs = ["process_skill_test.py"],
    deps = [
        ":models",
        ":process_skill",
        "@pypi//pytest",
        "@pypi//python_frontmatter",
    ],
)

py_test(
    name = "process_agent_test",
    srcs = ["process_agent_test.py"],
    deps = [
        ":models",
        ":process_agent",
        "@pypi//pytest",
        "@pypi//python_frontmatter",
    ],
)

py_binary(
    name = "process_gemini_extension",
    srcs = ["process_gemini_extension.py"],
    visibility = ["//visibility:public"],
    deps = [
        ":models",
        "@pypi//click",
        "@pypi//pydantic",
    ],
)

py_binary(
    name = "process_extension_command",
    srcs = ["process_extension_command.py"],
    visibility = ["//visibility:public"],
    deps = [
        "@pypi//click",
    ],
)
