"""
Validation tools package.

This package contains reusable validation tools that can be used
across the project for testing file formats and schemas.
"""

load("@rules_python//python:defs.bzl", "py_library")
load("@rules_shell//shell:sh_test.bzl", "sh_test")

package(default_visibility = ["//visibility:public"])

# JSON Schema validation tool
py_library(
    name = "json_schema_test",
    srcs = ["json_schema_test.py"],
    srcs_version = "PY3",
    deps = [
        "@pypi//jsonschema",
        "@pypi//pytest",
    ],
)

# Python tooling checks for json_schema_test.py
sh_test(
    name = "json_schema_test_format",
    srcs = ["//rules/common:ruff_wrapper"],
    args = [
        "format",
        "--check",
        "$(location json_schema_test.py)",
    ],
    data = ["json_schema_test.py"],
)

sh_test(
    name = "json_schema_test_lint",
    srcs = ["//rules/common:ruff_wrapper"],
    args = [
        "check",
        "$(location json_schema_test.py)",
    ],
    data = ["json_schema_test.py"],
)

sh_test(
    name = "json_schema_test_types",
    srcs = ["//rules/common:mypy_wrapper"],
    args = [
        "--ignore-missing-imports",
        "$(location json_schema_test.py)",
    ],
    data = ["json_schema_test.py"],
)

# Export the macro
exports_files(["json_schema_validation.bzl"])
