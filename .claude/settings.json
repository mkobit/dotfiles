{
  "permissions": {
    "allow": [
      "Bash(bazel build:*)",
      "Bash(bazel aquery:*)",
      "Bash(bazel cquery:*)",
      "Bash(bazel query:*)",
      "Bash(bazel run:*)",
      "Bash(bazel test:*)",
      "Bash(mkdir:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:jules.google)"
    ],
    "deny": [],
    "additionalDirectories": []
  },
  "hooks": {
    "PreToolUse": [],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bazel run //:format"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/bazel-validate.sh"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowRead": [
        "."
      ],
      "denyRead": [
        "~/.ssh",
        "~/.gnupg",
        "~/.aws",
        "~/.gcp",
        "~/.azure"
      ],
      "allowWrite": [
        ".",
        "~/.config",
        "~/.claude",
        "~/.cursor",
        "~/.local",
        "~/.dotfiles",
        "~/.gemini",
        "~/.codex",
        "~/.tmux.conf",
        "~/.vimrc",
        "~/.zshrc",
        "~/.gitconfig",
        "~/.local/share/chezmoi"
      ],
      "denyWrite": [
        "/"
      ]
    }
  }
}