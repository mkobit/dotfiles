{
  "permissions": {
    "allow": [
      "Bash(mkdir:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:jules.google)",
      "WebFetch(domain:www.chezmoi.io)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:chezmoi.io)",
      "Bash(chezmoi diff:*)",
      "Bash(chezmoi source-path:*)",
      "Bash(chezmoi status:*)",
      "Bash(chezmoi data:*)"
    ],
    "deny": [],
    "additionalDirectories": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/git-push-origin-main-guard.py"
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/git-commit-main-guard.py"
          }
        ]
      }
    ],
    "PostToolUse": [],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/worktree-context.py",
            "once": true
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": false,
    "filesystem": {
      "allowRead": [
        ".",
        "~/.config/gh"
      ],
      "denyRead": [
        "~/.ssh"
      ],
      "allowWrite": [
        ".",
        "~/.config",
        "~/.claude",
        "~/.cursor",
        "~/.local",
        "~/.dotfiles",
        "~/.gemini",
        "~/.codex",
        "~/.tmux.conf",
        "~/.vimrc",
        "~/.zshrc",
        "~/.gitconfig",
        "~/.local/share/chezmoi"
      ],
      "denyWrite": [
        "/"
      ]
    }
  }
}
