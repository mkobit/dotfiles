{
  "permissions": {
    "allow": [
      "Bash(mkdir:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:jules.google)",
      "WebFetch(domain:www.chezmoi.io)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:chezmoi.io)",
      "Bash(chezmoi diff:*)",
      "Bash(chezmoi source-path:*)",
      "Bash(chezmoi status:*)",
      "Bash(chezmoi data:*)"
    ],
    "deny": [],
    "additionalDirectories": []
  },
  "hooks": {
    "PreToolUse": [],
    "PostToolUse": []
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowRead": [
        ".",
        "~/.config/gh"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.gnupg",
        "~/.aws",
        "~/.gcp",
        "~/.azure"
      ],
      "allowWrite": [
        ".",
        "~/.config",
        "~/.claude",
        "~/.cursor",
        "~/.local",
        "~/.dotfiles",
        "~/.gemini",
        "~/.codex",
        "~/.tmux.conf",
        "~/.vimrc",
        "~/.zshrc",
        "~/.gitconfig",
        "~/.local/share/chezmoi"
      ],
      "denyWrite": [
        "/"
      ]
    }
  }
}
