load("//tools/agentskills:rules.bzl", "agent_skill", "claude_skill", "cursor_skill", "gemini_skill")

_NOT_WORK = select({
    "//src/ai/skills:work_machine": ["@platforms//:incompatible"],
    "//conditions:default": [],
})

agent_skill(
    name = "pr-reviewer",
    srcs = glob(["**/*"]),
    visibility = ["//src/ai/skills:__pkg__"],
)

claude_skill(
    name = "claude",
    install_name = "pr-reviewer",
    scope = "user",
    skill = ":pr-reviewer",
    target_compatible_with = _NOT_WORK,
    visibility = ["//visibility:public"],
)

gemini_skill(
    name = "gemini",
    install_name = "pr-reviewer",
    scope = "user",
    skill = ":pr-reviewer",
    target_compatible_with = _NOT_WORK,
    visibility = ["//visibility:public"],
)

cursor_skill(
    name = "cursor",
    install_name = "pr-reviewer",
    scope = "user",
    skill = ":pr-reviewer",
    target_compatible_with = _NOT_WORK,
    visibility = ["//visibility:public"],
)
