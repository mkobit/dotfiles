    install_name = "claude-api",
    scope = "user",
    skill = "@anthropics_skills//:claude-api",
    target_compatible_with = select({
        ":work_machine": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
)

gemini_skill(
    name = "frontend_design_gemini_skill",
    install_name = "frontend-design",
    scope = "user",
    skill = "@anthropics_skills//:frontend-design",
    target_compatible_with = select({
        ":work_machine": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
)

# gstack — TOMBSTONED. Triggers removal of ~/.claude/skills/gstack/ on next chezmoi apply.
#
# Why removed: gstack does not follow the agentskills.io SKILL.md format and is not a
# good upstream source for our pipeline. Specific problems:
#   - Every skill embeds a ~40-line gstack-specific preamble (telemetry, update checks,
#     session tracking, config reads) that fires on every skill invocation. All calls
#     use `|| true` fallbacks so they're silent, but the noise is still in every prompt.
#   - Skills are auto-generated from SKILL.md.tmpl via a bun build step; the deployed
#     SKILL.md files are derived artifacts, not authoritative sources.
#   - Several skills are gstack infrastructure, not general purpose (learn, freeze,
#     unfreeze, guard, canary, checkpoint manage gstack's own state machine).
#   - The bin/ scripts include telemetry sync, an uninstall script that modifies
#     ~/.claude/skills/, and dev-setup scripts not intended for managed deployments.
#   - The upstream deployment model (git clone + self-upgrade) conflicts with our
#     pinned, reproducible Bazel + chezmoi approach.
#
# Future: consider cherry-picking useful skills (review, health, qa, investigate,
# design-review, ship) as local src/ai/skills/ entries rewritten to our SKILL.md format,
# or find purpose-built upstream collections that follow agentskills.io conventions.
# See tools/agentskills/AGENTS.md for source evaluation criteria.
claude_skill_group(
    name = "gstack",
    srcs = ["@gstack//:skills"],
    namespace = "gstack",
    strip_prefix = "",
    tags = ["tombstone"],
    target_compatible_with = select({
        ":work_machine": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
)

# agency-agents engineering division — installs flat .md files to ~/.claude/agents/
filegroup(
    name = "agency_engineering",
    srcs = ["@agency_agents//:engineering-agents"],
    tags = ["claude:agents"],
    target_compatible_with = select({
        ":work_machine": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
)

# compound-engineering review agents — installs curated review personas to ~/.claude/agents/.
# Composed from individual atom targets; add/remove from _COMPOUND_REVIEW_AGENTS above.
# strip_prefix strips "plugins/compound-engineering/agents/review" so archives contain flat .md files.
claude_subagent_group(
    name = "compound_review_agents",
    srcs = _COMPOUND_REVIEW_AGENTS,
    install_name = "compound-review-agents",
    strip_prefix = "plugins/compound-engineering/agents/review",
    target_compatible_with = select({
        ":work_machine": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
)

# compound-engineering — skills to ~/.claude/skills/compound-engineering/
# 50+ general-purpose Claude plugin skills (ce-plan, ce-review, ce-work, etc.)
# Ingested via claude_plugin_repo; skills are already Claude-native (no transformation needed).
filegroup(
    name = "compound_engineering",
    srcs = ["@compound_engineering//:compound-engineering-skills"],
    tags = ["claude:collection"],
    target_compatible_with = select({
        ":work_machine": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
)

