load(
    "//tools/agentskills:defs.bzl",
    "claude_from_gemini_extension",
    "claude_skill_group",
    "claude_subagent_group",
    "gemini_skill",
)

# Disable AI skill targets on work machines where external network access is restricted.
config_setting(
    name = "work_machine",
    define_values = {"machine": "work"},
    visibility = ["//visibility:public"],
)

# Transform the Conductor Gemini extension into Claude-native commands and skill.
# Produces:
#   conductor.claude.commands.tar  (6 slash commands for ~/.claude/commands/conductor/)
#   conductor.claude.skill.tar     (context skill for ~/.claude/skills/conductor/)
claude_from_gemini_extension(
    name = "conductor",
    extension = "@gemini_conductor//:extension",
    install_name = "conductor",
    scope = "user",
    target_compatible_with = select({
        ":work_machine": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
)

# Transform selected Anthropic skills into Gemini skill format.
gemini_skill(
    name = "claude_api_gemini_skill",
    install_name = "claude-api",
    scope = "user",
    skill = "@anthropics_skills//:claude-api",
    target_compatible_with = select({
        ":work_machine": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
)

gemini_skill(
    name = "frontend_design_gemini_skill",
    install_name = "frontend-design",
    scope = "user",
    skill = "@anthropics_skills//:frontend-design",
    target_compatible_with = select({
        ":work_machine": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
)

# gstack — install curated namespace to ~/.claude/skills/gstack/.
# Selection (include/exclude) is configured in MODULE.bazel via the skill_collection tag.
# Use @gstack//:all-skills or load @gstack//:skills.bzl to override.
claude_skill_group(
    name = "gstack",
    srcs = ["@gstack//:skills"],
    namespace = "gstack",
    strip_prefix = "",
    target_compatible_with = select({
        ":work_machine": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
)

# agency-agents engineering division — installs flat .md files to ~/.claude/agents/
# strip_prefix strips the repo + division prefix so archive contains flat agent files.
claude_subagent_group(
    name = "agency_engineering",
    srcs = ["@agency_agents//:engineering"],
    install_name = "agency-engineering",
    strip_prefix = "engineering",
    target_compatible_with = select({
        ":work_machine": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
)
