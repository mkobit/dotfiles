#!/usr/bin/env python3
# Manages ~/.claude/settings.local.json — Claude Code hook registration.
# Hook definitions come from [data.claude.hooks] in .chezmoi.toml.tmpl.
# Each key is a hook event name; each value is the array of hook groups
# that Claude Code expects for that event.  No-op when no hooks are defined.
import json
import sys

try:
    existing = json.load(sys.stdin)
except Exception:
    existing = {}

managed_hooks = json.loads("""{{ with .claude }}{{ with .hooks }}{{ . | toJson }}{{ else }}null{{ end }}{{ else }}null{{ end }}""")

result = existing.copy()
if managed_hooks is not None:
    result["hooks"] = managed_hooks

print(json.dumps(result, indent=2, sort_keys=True), end="")
