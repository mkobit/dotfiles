{{- $workspace := output "git" "-C" .chezmoi.sourceDir "rev-parse" "--show-toplevel" | trim -}}
{{- if lookPath "bazel" -}}
{{- $_ := output "bash" "-c" (printf "cd %q && bazel build //src/ai/skills/..." $workspace) -}}
{{- end -}}
{{- $queryCmd := printf "cd %q && bazel cquery --output=files 'attr(tags, \"tool:claude\", //src/ai/skills/...) except attr(tags, \"skip-install\", //src/ai/skills/...)' 2>/dev/null" $workspace -}}
{{- $queryOutput := output "bash" "-c" $queryCmd -}}
{{- range $line := splitList "\n" $queryOutput -}}
{{- $line = trim $line -}}
{{- if $line -}}
{{- if hasSuffix ".claude.commands.tar" $line -}}
{{- $installName := base $line | trimSuffix ".claude.commands.tar" -}}

["commands/{{ $installName }}"]
    type = "archive"
    url = "file://{{ $workspace }}/{{ $line }}"
    exact = true

{{ end -}}
{{- if hasSuffix ".claude.skill.tar" $line -}}
{{- $installName := base $line | trimSuffix ".claude.skill.tar" -}}

["skills/{{ $installName }}"]
    type = "archive"
    url = "file://{{ $workspace }}/{{ $line }}"
    exact = true

{{ end -}}
{{- if hasSuffix ".claude.skill-group.tar" $line -}}
{{- $installName := base $line | trimSuffix ".claude.skill-group.tar" -}}

["skills/{{ $installName }}"]
    type = "archive"
    url = "file://{{ $workspace }}/{{ $line }}"
    exact = true

{{ end -}}
{{- end -}}
{{- end -}}
{{- $agentQueryCmd := printf "cd %q && bazel cquery --output=files 'attr(tags, \"tool:claude-agents\", //src/ai/skills/...) except attr(tags, \"skip-install\", //src/ai/skills/...)' 2>/dev/null" $workspace -}}
{{- $agentOutput := output "bash" "-c" $agentQueryCmd -}}
{{- range $line := splitList "\n" $agentOutput -}}
{{- $line = trim $line -}}
{{- if $line -}}
{{- if hasSuffix ".claude.agents.tar" $line -}}

["agents"]
    type = "archive"
    url = "file://{{ $workspace }}/{{ $line }}"
    exact = false

{{ end -}}
{{- end -}}
{{- end -}}
