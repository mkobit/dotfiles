{{- $workspace := output "git" "-C" .chezmoi.sourceDir "rev-parse" "--show-toplevel" | trim -}}
{{- if lookPath "bazel" -}}
{{- $_ := output "bash" "-c" (printf "cd %q && bazel build //src/ai/skills/..." $workspace) -}}
{{- end -}}
{{- $skip := "except attr(tags, \"skip-install\", //src/ai/skills/...) except attr(tags, \"tombstone\", //src/ai/skills/...)" -}}

{{- /* Commands: claude:commands tag → install to commands/<install_name>/ */ -}}
{{- $cmd := printf "cd %q && bazel cquery --output=files 'attr(tags, \"claude:commands\", //src/ai/skills/...) %s' 2>/dev/null" $workspace $skip -}}
{{- range $line := splitList "\n" (output "bash" "-c" $cmd) -}}
{{- $line = trim $line -}}
{{- if and $line (hasSuffix ".tar" $line) -}}
{{- $installName := base $line | trimSuffix ".claude.commands.tar" -}}

["commands/{{ $installName }}"]
    type = "archive"
    url = "file://{{ $workspace }}/{{ $line }}"
    exact = true

{{ end -}}
{{- end -}}

{{- /* Skills: claude:skill tag → install to skills/<install_name>/ */ -}}
{{- $skill := printf "cd %q && bazel cquery --output=files 'attr(tags, \"claude:skill\", //src/ai/skills/...) %s' 2>/dev/null" $workspace $skip -}}
{{- range $line := splitList "\n" (output "bash" "-c" $skill) -}}
{{- $line = trim $line -}}
{{- if and $line (hasSuffix ".tar" $line) -}}
{{- $installName := base $line | trimSuffix ".claude.skill.tar" -}}

["skills/{{ $installName }}"]
    type = "archive"
    url = "file://{{ $workspace }}/{{ $line }}"
    exact = true

{{ end -}}
{{- end -}}

{{- /* Skill groups: claude:collection tag → install to skills/<install_name>/ */ -}}
{{- $group := printf "cd %q && bazel cquery --output=files 'attr(tags, \"claude:collection\", //src/ai/skills/...) %s' 2>/dev/null" $workspace $skip -}}
{{- range $line := splitList "\n" (output "bash" "-c" $group) -}}
{{- $line = trim $line -}}
{{- if and $line (hasSuffix ".tar" $line) -}}
{{- $installName := base $line | trimSuffix ".claude.skill-group.tar" -}}

["skills/{{ $installName }}"]
    type = "archive"
    url = "file://{{ $workspace }}/{{ $line }}"
    exact = true

{{ end -}}
{{- end -}}

{{- /* Agents: claude:agents tag → install to agents/ */ -}}
{{- $agents := printf "cd %q && bazel cquery --output=files 'attr(tags, \"claude:agents\", //src/ai/skills/...) %s' 2>/dev/null" $workspace $skip -}}
{{- range $line := splitList "\n" (output "bash" "-c" $agents) -}}
{{- $line = trim $line -}}
{{- if and $line (hasSuffix ".tar" $line) -}}

["agents"]
    type = "archive"
    url = "file://{{ $workspace }}/{{ $line }}"
    exact = false

{{ end -}}
{{- end -}}
