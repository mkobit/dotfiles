{{- if eq .claude_code.installation_method "dotfiles.script" -}}
#!/usr/bin/env python3
# Manages ~/.claude/settings.json — deployment config only.
# UI preferences (editorMode, etc.) live in ~/.claude.json; see modify_dot_claude.json.tmpl.
import json
import sys

try:
    existing = json.load(sys.stdin)
except Exception:
    existing = {}

managed = json.loads("""{{ .claude_code.settings | toPrettyJson }}""")

merged = {**existing, **managed}

def sort_keys(obj):
    if isinstance(obj, dict):
        return {k: sort_keys(v) for k, v in sorted(obj.items())}
    elif isinstance(obj, list):
        return [sort_keys(i) for i in obj]
    return obj

print(json.dumps(sort_keys(merged), indent=2))
{{- end }}
