{{- /*
  All keybinds live in a single top-level keybinds block.
  Zellij does not merge multiple top-level keybinds blocks — only the first is used.
  The shared_except block (tmux unbind) is always emitted; overlay modes are appended
  inside the same block via data injection.

  Data path: zellij.modes.<mode>.keybinds
    Keys:   unique bind identifiers (merge key only, not emitted)
    Values: raw KDL bind statement, or empty string to suppress a bind from an inner layer
  clear_defaults = true on a mode emits a separate "keybinds clear-defaults=true" block
  (must be separate since clear-defaults applies to the whole block).
  Custom modes unsupported until: https://github.com/zellij-org/zellij/issues/248
*/ -}}
{{- $normalModes := dict -}}
{{- range $mode, $modeData := (dig "zellij" "modes" (dict) .) -}}
{{-   if and (dig "keybinds" (dict) $modeData) (not (dig "clear_defaults" false $modeData)) -}}
{{-     $_ := set $normalModes $mode $modeData -}}
{{-   end -}}
{{- end -}}
// Keybind overrides — zellij built-in defaults are preserved.
// https://zellij.dev/documentation/keybindings
keybinds {
    shared_except "locked" "scroll" "search" "tmux" {
        unbind "Ctrl b"
    }
{{- range $mode, $modeData := $normalModes }}
    {{ $mode }} {
{{-     range $_, $line := dig "keybinds" (dict) $modeData }}
{{-       if $line }}
        {{ $line }}
{{-       end }}
{{-     end }}
    }
{{- end }}
}
{{- range $mode, $modeData := (dig "zellij" "modes" (dict) .) }}
{{-   $keybinds := dig "keybinds" (dict) $modeData }}
{{-   if and $keybinds (dig "clear_defaults" false $modeData) }}
keybinds clear-defaults=true {
    {{ $mode }} {
{{-     range $_, $line := $keybinds }}
{{-       if $line }}
        {{ $line }}
{{-       end }}
{{-     end }}
    }
}
{{-   end }}
{{- end }}

// Plugin aliases — alias name → location URL with optional config block.
// Data path: zellij.plugins.<alias>.location + zellij.plugins.<alias>.config
// Overlay environments add aliases or override existing ones via [data.zellij.plugins.*].
// https://zellij.dev/documentation/plugin-aliases
plugins {
{{- range $alias, $plugin := (dig "zellij" "plugins" (dict) .) }}
    {{ $alias }} location={{ dig "location" "" $plugin | quote }}
{{-   $cfg := dig "config" (dict) $plugin }}
{{-   if $cfg }} {
{{-     range $k, $v := $cfg }}
        {{ $k }} {{ if eq (kindOf $v) "string" }}{{ $v | quote }}{{ else }}{{ $v }}{{ end }}
{{-     end }}
    }{{ end }}
{{- end }}
}

// Plugins loaded in the background on session start.
// Data path: zellij.load_plugins — keys are alias names or URLs, false suppresses.
// https://zellij.dev/documentation/plugin-loading
load_plugins {
{{- range $location, $enabled := (dig "zellij" "load_plugins" (dict) .) }}
{{-   if $enabled }}
    {{ $location }}
{{-   end }}
{{- end }}
}

web_client {
    font "monospace"
}

// https://zellij.dev/documentation/options#simplified_ui
simplified_ui true

// https://zellij.dev/documentation/options#pane_frames
pane_frames true

// https://zellij.dev/documentation/options#on_force_close
on_force_close "detach"

// https://zellij.dev/documentation/options#session_serialization
session_serialization true

// https://zellij.dev/documentation/options#serialize_pane_viewport
serialize_pane_viewport true

// https://zellij.dev/documentation/options#scrollback_lines_to_serialize
scrollback_lines_to_serialize {{ .zellij.config.scrollback_lines_to_serialize }}

// https://zellij.dev/documentation/options#show_startup_tips
show_startup_tips {{ .zellij.config.show_startup_tips }}
