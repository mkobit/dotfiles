{{- /*
  home.kdl.tmpl — "home" session layout.

  Tab/pane data is injected by the work repo via [data.zellij.sessions.home]
  in chezmoi-personal.toml.tmpl. Personal machines have this session disabled
  by default (enabled = false in .chezmoidata/zellij.toml).

  Docs: https://zellij.dev/documentation/creating-a-layout
*/ -}}
{{- $session := dig "zellij" "sessions" "home" (dict) . -}}
{{- if not (dig "enabled" false $session) }}{{- fail "zellij home: session is disabled — enable via [data.zellij.sessions.home] enabled=true" }}{{- end -}}
{{- $style := dig "layout_style" "^work" $session -}}
{{- $tabs  := dig "tabs" list $session -}}
{{- if not $tabs }}{{- fail "zellij home: no tabs defined — add [[data.zellij.sessions.home.tabs]] entries" }}{{- end -}}
layout {
{{- template "zellij/chrome.kdl.tmpl" (dict "style" $style "position" "top"    "root" .) }}
{{- range $tabs }}
{{-   template "zellij/tab.kdl.tmpl" . }}
{{- end }}
{{- template "zellij/chrome.kdl.tmpl" (dict "style" $style "position" "bottom" "root" .) }}
}
