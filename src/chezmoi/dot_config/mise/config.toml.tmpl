{{- $hasEnabledTools := false -}}
{{- range $tool, $config := .mise.global_tools -}}
  {{- if eq (dig "installation" "mise" $config) "mise" -}}
    {{- $hasEnabledTools = true -}}
  {{- end -}}
{{- end -}}
{{- if $hasEnabledTools -}}
[tools]
{{- range $tool, $config := .mise.global_tools -}}
  {{- if eq (dig "installation" "mise" $config) "mise" }}
    {{- if hasKey $config "postinstall" }}
{{ $tool | quote }} = { version = "{{ $config.version }}", postinstall = "{{ $config.postinstall }}" }
    {{- else }}
{{ $tool | quote }} = "{{ $config.version }}"
    {{- end }}
  {{- end -}}
{{- end -}}
{{- end -}}

{{- if hasKey .mise "settings" }}
[settings]
{{- range $key, $value := .mise.settings }}
{{- if kindIs "map" $value }}
{{- range $subkey, $subval := $value }}
{{ $key }}.{{ $subkey }} = {{ $subval | toJson }}
{{- end }}
{{- else }}
{{ $key }} = {{ $value | toJson }}
{{- end }}
{{- end }}
{{- end -}}
