{{- $hasEnabledTools := false -}}
{{- range $tool, $config := .mise.global_tools -}}
  {{- if eq (dig "installation" "mise" $config) "mise" -}}
    {{- $hasEnabledTools = true -}}
  {{- end -}}
{{- end -}}
{{- if $hasEnabledTools -}}
[tools]
{{- range $tool, $config := .mise.global_tools -}}
  {{- if eq (dig "installation" "mise" $config) "mise" }}
    {{- if hasKey $config "postinstall" }}
{{ $tool | quote }} = { version = "{{ $config.version }}", postinstall = "{{ $config.postinstall }}" }
    {{- else }}
{{ $tool | quote }} = "{{ $config.version }}"
    {{- end }}
  {{- end -}}
{{- end -}}
{{- end -}}

{{- if hasKey .mise "settings" }}
[settings]
{{- range $key, $value := .mise.settings }}
{{- if typeIs "map[string]interface {}" $value }}
  {{- range $subKey, $subValue := $value }}
  {{- /* Skip npm.package_manager=bun when bun is disabled */ -}}
  {{- if and (eq $key "npm") (eq $subKey "package_manager") (eq $subValue "bun") (eq (dig "mise" "global_tools" "bun" "installation" "mise" $) "disabled") }}
  {{- else }}
  {{ $key }}.{{ $subKey }} = {{ $subValue | toJson }}
  {{- end }}
  {{- end }}
{{- else }}
{{ $key }} = {{ $value | toJson }}
{{- end }}
{{- end }}
{{- end -}}
