"$schema" = 'https://starship.rs/config-schema.json'

add_newline = true
palette     = "tokyo_night"

[palettes.tokyo_night]
red     = "#f7768e"
green   = "#9ece6a"
yellow  = "#e0af68"
blue    = "#7aa2f7"
purple  = "#bb9af7"
cyan    = "#7dcfff"
orange  = "#ff9e64"
comment = "#565f89"

# disabled until zellij config is wired up
[shlvl]
disabled = true

[directory]
truncation_length = 2

[git_branch]
truncation_length = 15

[git_commit]
tag_disabled = false

[git_status]
ahead    = "⇡${count}"
behind   = "⇣${count}"
diverged = "[⇣${behind_count}](red)⇕[⇡${ahead_count}](green)"

[character]
success_symbol = "[\uf0a9](bold green)"  # nf-fa-circle_arrow_right
error_symbol   = "[\uf0a9](bold red)"    # nf-fa-circle_arrow_right
vimcmd_symbol  = "[\uf0a9](bold blue)"   # nf-fa-circle_arrow_right

[package]
disabled = true

[status]
disabled = false

[cmd_duration]
min_time = 2000
style    = "comment"
format   = "[\uf017$duration]($style) "  # nf-fa-clock_o

# only fires on .node-version / .nvmrc, not package.json
[nodejs]
detect_files      = [".node-version", ".nvmrc"]
detect_folders    = []
detect_extensions = []
version_format    = "v${major}"

[custom.obsidian]
detect_folders = [".obsidian"]
format         = "on [󰋊 Vault]($style) "
style          = "bold #8B5CF6"

{{- if hasKey .starship "custom_modules" }}
{{- range $name, $mod := .starship.custom_modules }}

[custom.{{ $name }}]
{{ $mod | toToml -}}
{{- end }}
{{- end }}
