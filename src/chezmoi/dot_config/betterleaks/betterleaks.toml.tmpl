{{- /* Global betterleaks config, shared across every repo the pre-commit hook
       runs in (passed via `betterleaks git -c`). Values come from
       .chezmoidata/betterleaks.toml. Deploys only when the pre_commit hook is
       enabled AND every bin tool it declares in git_hooks.pre_commit.requires_bin
       is installed — the hook→tool dependency is data-driven, not hardcoded.
       Renders empty (→ removed by chezmoi) otherwise. */ -}}
{{- $hook   := dig "git_hooks" "pre_commit" (dict) . -}}
{{- $depsOk := eq (dig "installation_method" "none" $hook) "chezmoi" -}}
{{- range (dig "requires_bin" (list) $hook) -}}
{{-   if eq (dig . "installation_method" "none" (dig "local" "bin" (dict) $)) "none" -}}{{- $depsOk = false -}}{{- end -}}
{{- end -}}
{{- if $depsOk -}}
{{- $c := .betterleaks.config -}}
# Managed by chezmoi — edit .chezmoidata/betterleaks.toml, not this file.
title = {{ $c.title | quote }}

[extend]
useDefault = {{ $c.use_default_rules }}
{{ if or $c.allowlist.paths $c.allowlist.regexes $c.allowlist.stopwords }}
[[allowlists]]
description = {{ $c.allowlist.description | quote }}
{{- with $c.allowlist.paths }}
paths = [{{ range $i, $p := . }}{{ if $i }}, {{ end }}{{ $p | quote }}{{ end }}]
{{- end }}
{{- with $c.allowlist.regexes }}
regexes = [{{ range $i, $r := . }}{{ if $i }}, {{ end }}{{ $r | quote }}{{ end }}]
{{- end }}
{{- with $c.allowlist.stopwords }}
stopwords = [{{ range $i, $s := . }}{{ if $i }}, {{ end }}{{ $s | quote }}{{ end }}]
{{- end }}
{{- end }}
{{- end -}}
