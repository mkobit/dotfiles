{{- /*
  Generates archive externals for the skills catalog in .chezmoidata/ai/skills.toml.
  To minimize Python filter executions, skills from the same source are grouped
  into a single archive external under a hidden source directory.
  Symlinks are created post-apply by run_onchange_after_symlink-ai-skills.sh.tmpl.
*/ -}}
{{- $cfg := .ai.skills -}}
{{- $tools := dict "claude" ".claude/skills" "antigravity" ".gemini/antigravity-cli/skills" "cursor" ".cursor/skills" "codex" ".codex/skills" -}}
{{- $python := "/usr/bin/python3" -}}
{{- $script := joinPath .chezmoi.workingTree "src/python/skill_filter/skill_filter/main.py" -}}
{{- $config := dict -}}
{{- range $sourceName, $source := $cfg.external -}}
{{-   if or (not (dig "ref" "" $source)) (not (dig "sha256" "" $source)) -}}
{{-     fail (printf "ai.skills.external.%s: ref and sha256 are required" $sourceName) -}}
{{-   end -}}
{{-   $url := dig "url" "" $source -}}
{{-   if not $url -}}
{{-     $hostName := dig "host" "github" $source -}}
{{-     $host := dig $hostName (dict) $cfg.hosts -}}
{{-      if not $host -}}
{{-        fail (printf "ai.skills.external.%s: unknown host %q" $sourceName $hostName) -}}
{{-      end -}}
{{-      $url = $host.url_format | replace "{repo}" $source.repo | replace "{ref}" $source.ref -}}
{{-   end -}}
{{-   $skillsRoot := dig "skills_root" "skills" $source -}}
{{-   range $toolName, $skillsDir := $tools -}}
{{-     $selects := list -}}
{{-     range $skillName, $state := dig "skills" (dict) $source -}}
{{-       if or (eq $state "present") (eq $state $toolName) -}}
{{-         $path := printf "%s/%s" $skillsRoot $skillName -}}
{{-         $selects = concat $selects (list "--select" (printf "%s:%s" $path $skillName)) -}}
{{-       else if and (ne $state "absent") (not (hasKey $tools $state)) -}}
{{-         fail (printf "ai.skills.external.%s.skills.%s: invalid state %q" $sourceName $skillName $state) -}}
{{-       end -}}
{{-     end -}}
{{-     if $selects -}}
{{-       $sourceDir := printf ".source-%s" $sourceName -}}
{{-       $archiveKey := printf "%s/%s" $skillsDir $sourceDir -}}
{{-       $archiveEntry := dict
            "type" "archive"
            "url" $url
            "checksum" (dict "sha256" $source.sha256)
            "exact" true
            "format" "tar"
            "filter" (dict
              "command" $python
              "args" (concat (list $script "--cache-key" $source.sha256) $selects))
       -}}
{{-       $_ := set $config $archiveKey $archiveEntry -}}
{{-     end -}}
{{-   end -}}
{{- end -}}
{{- if $config -}}{{- toToml $config -}}{{- end -}}
