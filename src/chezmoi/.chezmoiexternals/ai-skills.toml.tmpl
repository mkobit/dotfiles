{{- /*
  Generates one archive external per (present skill, active tool) from the
  catalog in .chezmoidata/ai/skills.toml. Each external downloads the pinned
  upstream archive (verified against sha256, cached once per URL) and pipes it
  through skill_filter to re-root a single skill directory at the target.
  The filter runs via system python3 and must stay stdlib-only because uv and
  mise are not installed until after apply. Target directories are fixed by
  each tool's skill discovery and are hardcoded here; overlays deselect skills
  via "absent" states rather than disabling a target.
*/ -}}
{{- $cfg := .ai.skills -}}
{{- $skillsDirs := list ".claude/skills" ".gemini/antigravity-cli/skills" -}}
{{- $script := joinPath .chezmoi.workingTree "src/python/skill_filter/skill_filter/main.py" -}}
{{- $config := dict -}}
{{- range $sourceName, $source := $cfg.external -}}
{{-   range $skillName, $state := dig "skills" (dict) $source -}}
{{-     if eq $state "present" -}}
{{-       if or (not (dig "ref" "" $source)) (not (dig "sha256" "" $source)) -}}
{{-         fail (printf "ai.skills.external.%s: ref and sha256 are required (versions are always pinned)" $sourceName) -}}
{{-       end -}}
{{-       $url := dig "url" "" $source -}}
{{-       if not $url -}}
{{-         $url = printf "%s/%s/tar.gz/%s" $cfg.github_archives.base_url $source.repo $source.ref -}}
{{-       end -}}
{{-       $path := printf "%s/%s" (dig "skills_root" "skills" $source) $skillName -}}
{{-       range $skillsDir := $skillsDirs -}}
{{-         $entry := dict
              "type" "archive"
              "url" $url
              "checksum" (dict "sha256" $source.sha256)
              "exact" true
              "format" "tar"
              "filter" (dict
                "command" "python3"
                "args" (list $script "--select" (printf "%s:." $path)))
-}}
{{-         $_ := set $config (printf "%s/%s" $skillsDir $skillName) $entry -}}
{{-       end -}}
{{-     else if ne $state "absent" -}}
{{-       fail (printf "ai.skills.external.%s.skills.%s: state must be \"present\" or \"absent\", got %q" $sourceName $skillName $state) -}}
{{-     end -}}
{{-   end -}}
{{- end -}}
{{- if $config -}}{{- toToml $config -}}{{- end -}}
