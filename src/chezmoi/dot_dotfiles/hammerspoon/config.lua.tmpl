-- Hammerspoon configuration managed by chezmoi
-- This file sources all individual config snippets

-- Global Configuration Table
_G.DotfilesConfig = {
    cache_dir = "{{ .chezmoi.destDir }}/.cache",
    window_manager = {
        enabled = {{ .hammerspoon.window_manager.enabled | default "false" }}
    },
    chrome = {
        hotkeys = {
            {{- with dig "hammerspoon" "chrome" "hotkeys" "vertical_tabs" nil . }}
            vertical_tabs = { mods = { {{ range .mods }}"{{ . }}", {{ end }} }, key = "{{ .key }}" },
            {{- end }}
        },
    },
}

-- Load base configuration
dofile("{{ .chezmoi.destDir }}/.dotfiles/hammerspoon/snippets/init.lua")

{{ range (dig "chrome" "features" (list) .hammerspoon) -}}
dofile("{{ $.chezmoi.destDir }}/.dotfiles/hammerspoon/snippets/chrome-{{ . }}.lua")
{{ end -}}
