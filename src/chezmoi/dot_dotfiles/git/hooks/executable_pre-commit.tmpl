{{- /* Deployed to <destDir>/.dotfiles/git/hooks/pre-commit and wired via
       core.hooksPath (snippets/hooks.gitconfig, mkobit remotes only). Gated on
       the git_hooks.pre_commit BOM knob — renders empty when "none", so chezmoi
       removes the file and no hook runs. The betterleaks binary is a separate
       knob; if the hook is on but the binary off, the runtime check below fails
       gracefully. Antigravity artifacts are handled by gitignore, not here. */ -}}
{{- if eq (dig "pre_commit" "installation_method" "none" (dig "git_hooks" (dict) .)) "chezmoi" -}}
#!/usr/bin/env bash
set -euo pipefail

# Scan staged changes for secrets with betterleaks, using the chezmoi-managed
# global config (one ruleset/allowlist for every repo this hook runs in).
scanner="{{ .chezmoi.destDir }}/.local/bin/betterleaks"
[[ -x "$scanner" ]] || scanner="$(command -v betterleaks || true)"
if [[ -z "$scanner" ]]; then
  echo "pre-commit: betterleaks not found though enabled in the chezmoi BOM — run chezmoi apply" >&2
  exit 1
fi

args=(git --staged --redact --no-banner)
config="{{ .chezmoi.destDir }}/.config/betterleaks/betterleaks.toml"
[[ -f "$config" ]] && args+=(-c "$config")
exec "$scanner" "${args[@]}"
{{- end -}}
