{{- with .eza -}}
{{- $method := dig "packages" "eza" "installation_method" $.chezmoi.os "" $ -}}
{{- if eq $method "chezmoi_external" -}}
{{- template "external/release" (dict "key" "eza-completions" "data" (dict
    "version"             .version
    "installation_method" $method
    "repo"                "eza-community/eza"
    "external_type"       "archive"
    "checksum_type"       "none"
    "tag_format"          "v{version}"
    "filename_format"     "completions-{version}.tar.gz"
    "url_format"          "{base}/{repo}/releases/download/{tag}/{filename}"
    "include"             (list "*/_eza")
    "stripComponents"     2
    "readonly"            true
    "platforms"           .platforms
) "root" $) -}}
{{- end -}}
{{- end -}}
