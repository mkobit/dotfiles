{{ with (index .zsh "oh-my-zsh") }}
{{- $prompt := default "starship" $.zsh.prompt -}}
{{- $installation := default "external-sources" (get . "installation") -}}
{{ if and (eq $prompt "oh-my-zsh") (eq $installation "external-sources") }}
["oh-my-zsh"]
    type = "archive"
    url = "https://github.com/ohmyzsh/ohmyzsh/archive/{{ .sha }}.tar.gz"
    exact = true
    stripComponents = 1

{{ if .powerlevel10k.enabled }}
["oh-my-zsh/custom/themes/powerlevel10k"]
    type = "archive"
    url = "https://github.com/romkatv/powerlevel10k/archive/refs/tags/{{ .powerlevel10k.version }}.tar.gz"
    exact = true
    stripComponents = 1
{{ end }}
{{ end }}
{{ end }}
