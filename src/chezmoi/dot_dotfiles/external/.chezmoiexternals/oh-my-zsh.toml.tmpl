{{- with (index .zsh "oh-my-zsh") -}}
{{- $prompt := default "starship" $.zsh.prompt -}}
{{- $installation := default "external-sources" (get . "installation") -}}
{{- if and (eq $prompt "oh-my-zsh") (eq $installation "external-sources") -}}
{{- $config := dict -}}
{{- $ohMyZsh := dict
    "type" "archive"
    "url" (printf "https://github.com/ohmyzsh/ohmyzsh/archive/%s.tar.gz" .sha)
    "exact" true
    "stripComponents" 1
-}}
{{- $_ := set $config "oh-my-zsh" $ohMyZsh -}}
{{- toToml $config -}}
{{- end -}}
{{- end -}}
