{{- /*
  zellij/tab.kdl.tmpl — render a single KDL tab node.

  Call as:
    {{- template "zellij/tab.kdl.tmpl" $tab }}

  Context fields:
    name             string   required — tab display name; template fails without it
    focus            bool     optional — select this tab on session open
    cwd              string   optional — single-pane working directory
    command          string   optional — single-pane executable (no shell)
    args             []string optional — single-pane args for command
    startup_cmd      string   optional — single-pane sugar: split on spaces into
                                         command+args; mutually exclusive with
                                         command/args
    split_direction  string   optional — "Horizontal" | "Vertical"; required when
                                         panes is set; defaults to "Horizontal" if
                                         panes is set but split_direction is absent
    panes            []map    optional — child pane dicts; triggers split layout;
                                         each entry takes the same fields as
                                         pane.kdl.tmpl (except _indent, set here)

  Constraints:
    - name is required; template fails without it
    - split_direction without panes is invalid; template fails
    - single-pane fields (cwd, command, startup_cmd) are silently ignored when
      panes is set — define those fields on individual pane entries instead

  Output contract:
    Emits a leading "\n" then the tab block at 4-space depth.
    Does NOT emit a trailing newline.
    The layout file must use "{{- range ... }}" or "{{- template ... }}" to strip
    inter-tab whitespace in the template source.

  Docs:
    https://zellij.dev/documentation/creating-a-layout#tabs
    https://zellij.dev/documentation/creating-a-layout#split_direction
    https://zellij.dev/documentation/creating-a-layout#focus-1
    https://zellij.dev/documentation/creating-a-layout#cwd-1
    https://kdl.dev/spec
*/ -}}
{{- /* ── validation ─────────────────────────────────────────────────────── */ -}}
{{- $name  := dig "name" "" . -}}
{{- if not $name }}{{- fail "zellij tab: 'name' is required" }}{{- end -}}
{{- $panes := dig "panes" list . -}}
{{- $split := dig "split_direction" "" . -}}
{{- if and $split (not $panes) -}}
{{-   fail (printf "zellij tab %q: split_direction set but panes is empty" $name) -}}
{{- end -}}
{{- if and $panes (not $split) -}}
{{-   $split = "Horizontal" -}}
{{- end -}}
{{- /* ── tab attribute list ───────────────────────────────────────────────── */ -}}
{{- $attrs := list (printf "name=%q" $name) -}}
{{- if dig "focus" false . }}{{- $attrs = append $attrs "focus=true" }}{{- end }}
    tab {{ join " " $attrs }} {
{{- if $panes }}
        pane split_direction={{ $split | quote }} {
{{-     range $panes }}
{{-       template "zellij/pane.kdl.tmpl" (merge (dict "_indent" "            ") .) }}
{{-     end }}
        }
{{- else }}
{{-   template "zellij/pane.kdl.tmpl" (dict
        "_indent"     "        "
        "name"        (dig "name"        "" $)
        "cwd"         (dig "cwd"         "" $)
        "focus"       (dig "focus"       false $)
        "command"     (dig "command"     "" $)
        "args"        (dig "args"        list $)
        "startup_cmd" (dig "startup_cmd" "" $)
      ) }}
{{- end }}
    }{{- /* no trailing newline — output contract */ -}}
