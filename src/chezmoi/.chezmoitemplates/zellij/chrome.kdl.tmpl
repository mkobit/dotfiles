{{- /*
  zellij/chrome.kdl.tmpl — render layout chrome panes (tab-bar / status-bar).

  Layout files call this template twice: once before tabs ("top") and once
  after tabs ("bottom"). When a position has no chrome for the active style
  the template emits nothing, making both calls safe for all styles.

  Call as:
    {{- template "zellij/chrome.kdl.tmpl" (dict "style" $style "position" "top"    "root" $) }}
    ... tab nodes ...
    {{- template "zellij/chrome.kdl.tmpl" (dict "style" $style "position" "bottom" "root" $) }}

  Context fields:
    style     string   required — style name; bare string uses a built-in;
                                 "^name" resolves via .zellij.styles.<name> in root
    position  string   required — "top" | "bottom"
    root      map      required — full template root ($) for "^name" resolution

  Built-in styles and what each position emits:

    style      | top                  | bottom
    -----------|----------------------|---------------------
    work       | tab-bar (size=1)     | status-bar (size=2)
    compact    | (nothing)            | compact-bar (size=1)
    personal   | (nothing)            | compact-bar (size=1)
    minimal    | (nothing)            | (nothing)

  Named style resolution ("^id"):
    Strips "^", looks up .zellij.styles.<name> in root for a resolved style string.
    Falls through to built-in matching if the key is absent.
    This hook lets future named theme data override chrome without changing layout
    files — all layouts already reference styles by name.

  Output contract:
    Emits zero or one pane block at 4-space depth with a trailing newline.
    Emits nothing (zero bytes) when the position has no chrome for the style.
    No leading newline. Callers do not need to guard against empty output.

  Docs:
    https://zellij.dev/documentation/creating-a-layout#pane-templates
    https://zellij.dev/documentation/creating-a-layout#plugin
    https://kdl.dev/spec
*/ -}}
{{- /* ── validate position ───────────────────────────────────────────────── */ -}}
{{- $pos := dig "position" "" . -}}
{{- if not (or (eq $pos "top") (eq $pos "bottom")) -}}
{{-   fail (printf "zellij chrome: position must be \"top\" or \"bottom\", got %q" $pos) -}}
{{- end -}}
{{- /* ── resolve style name (strip "^" and look up in data if present) ────── */ -}}
{{- $styleName := dig "style" "work" . -}}
{{- if hasPrefix "^" $styleName -}}
{{-   $key      := trimPrefix "^" $styleName -}}
{{-   $resolved := dig "zellij" "styles" $key "" (dig "root" (dict) .) -}}
{{-   $styleName = $resolved | default $key -}}
{{- end -}}
{{- /* ── emit chrome node for this style + position ────────────────────────── */ -}}
{{- if eq $styleName "work" -}}
{{-   if eq $pos "top" }}
    pane size=1 borderless=true {
        plugin location="tab-bar"
    }
{{-   else }}
    pane size=2 borderless=true {
        plugin location="status-bar"
    }
{{-   end -}}
{{- else if or (eq $styleName "compact") (eq $styleName "personal") -}}
{{-   if eq $pos "bottom" }}
    pane size=1 borderless=true {
        plugin location="compact-bar"
    }
{{-   end -}}
{{- else if eq $styleName "minimal" -}}
{{- /* minimal: no chrome at any position — intentional */ -}}
{{- else -}}
{{-   fail (printf "zellij chrome: unknown layout_style %q (built-ins: work, compact, personal, minimal; prefix ^ for named styles)" $styleName) -}}
{{- end -}}
