{{- /*
  zellij/pane.kdl.tmpl — render a single KDL pane node.

  Call as:
    {{- template "zellij/pane.kdl.tmpl" $pane }}

  Context fields:
    _indent      string   optional — leading whitespace for the pane keyword
                          (default: 8 spaces = depth inside tab > layout).
                          Increase by 4 spaces for each extra nesting level
                          (e.g. "            " for panes inside a split container).
    name         string   optional — pane display name
    cwd          string   optional — working directory
    focus        bool     optional — give this pane initial focus
    borderless   bool     optional — hide pane border
    size         string   optional — e.g. "20%", "10" (rows/cols)
    command      string   optional — executable to run directly (no shell)
    args         []string optional — arguments passed to command
    startup_cmd  string   optional — sugar: first whitespace-delimited token →
                                     command, remainder → args; mutually exclusive
                                     with command/args

  Constraints:
    - startup_cmd and command/args are mutually exclusive; template fails if both set
    - split_direction does not belong here; set it on the parent tab node
    - a pane with none of the optional fields opens the default shell

  Output contract:
    Emits a leading "\n" then the pane node at _indent depth.
    Does NOT emit a trailing newline.
    Callers must provide any closing-brace newlines themselves.

  Docs:
    https://zellij.dev/documentation/creating-a-layout#panes
    https://zellij.dev/documentation/creating-a-layout#command
    https://zellij.dev/documentation/creating-a-layout#args
    https://zellij.dev/documentation/creating-a-layout#cwd
    https://zellij.dev/documentation/creating-a-layout#focus
    https://zellij.dev/documentation/creating-a-layout#borderless
    https://zellij.dev/documentation/creating-a-layout#size
    https://kdl.dev/spec
*/ -}}
{{- /* ── resolve indent ──────────────────────────────────────────────────── */ -}}
{{- $indent      := dig "_indent" "        " . -}}
{{- $childIndent := printf "%s    " $indent -}}
{{- /* ── validation ─────────────────────────────────────────────────────── */ -}}
{{- $hasStartupCmd := ne (dig "startup_cmd" "" .) "" -}}
{{- $hasCommand    := ne (dig "command"     "" .) "" -}}
{{- if and $hasStartupCmd $hasCommand -}}
{{-   fail (printf "zellij pane %q: startup_cmd and command are mutually exclusive" (dig "name" "<unnamed>" .)) -}}
{{- end -}}
{{- /* ── resolve command + args (startup_cmd splits on whitespace) ────────── */ -}}
{{- $cmd  := dig "command" "" . -}}
{{- $args := dig "args"    list . -}}
{{- if $hasStartupCmd -}}
{{-   $parts := splitList " " .startup_cmd -}}
{{-   $cmd    = first $parts -}}
{{-   $args   = rest  $parts -}}
{{- end -}}
{{- /* ── build inline attribute list ─────────────────────────────────────── */ -}}
{{- $attrs := list -}}
{{- with dig "name"       "" . }}{{- $attrs = append $attrs (printf "name=%q"    .) }}{{- end -}}
{{- with dig "cwd"        "" . }}{{- $attrs = append $attrs (printf "cwd=%q"     .) }}{{- end -}}
{{- if   dig "focus"      false . }}{{- $attrs = append $attrs "focus=true"          }}{{- end -}}
{{- if   dig "borderless" false . }}{{- $attrs = append $attrs "borderless=true"      }}{{- end -}}
{{- with dig "size"       "" . }}{{- $attrs = append $attrs (printf "size=%q"    .) }}{{- end }}
{{ $indent }}pane{{ if $attrs }} {{ join " " $attrs }}{{ end }}{{ if $cmd }} {
{{ $childIndent }}command {{ $cmd | quote }}
{{- if $args }}
{{ $childIndent }}args{{ range $args }} {{ . | quote }}{{ end }}
{{- end }}
{{ $indent }}}{{- end -}}
