{{- /*
  Emits a chezmoi externals TOML block for one github_releases tool.
  Context dict keys: name, tool (root bin entry), platform, base (github base URL).
*/ -}}
{{- $name     := .name -}}
{{- $tool     := .tool -}}
{{- $platform := .platform -}}
{{- $base     := .base -}}
{{- $gr       := $tool.github_releases -}}

{{- $target := dig "platforms" $platform "" $gr -}}
{{- if not (hasKey $gr.platforms $platform) -}}
{{-   fail (printf "bin.%s: no github_releases platform entry for %s" $name $platform) -}}
{{- end -}}

{{- $parts  := splitList "_" $platform -}}
{{- $os     := first $parts -}}
{{- $arch   := last $parts -}}
{{- $ext    := dig "ext" $platform "" $gr -}}

{{- $tag      := $gr.tag_format      | replace "{version}" $tool.version -}}
{{- $filename := $gr.filename_format | replace "{version}" $tool.version | replace "{target}" $target | replace "{ext}" $ext | replace "{os}" $os | replace "{arch}" $arch -}}
{{- $url      := $gr.url_format      | replace "{base}" $base | replace "{repo}" $gr.repo | replace "{tag}" $tag | replace "{filename}" $filename -}}
{{- $checksum := dig "checksums" $platform "" $gr -}}

{{- $binName := dig "path_format" "" $gr | splitList "/" | last -}}
{{- if not $binName -}}{{- $binName = $name -}}{{- end -}}

["{{ $binName }}"]
type       = {{ $gr.external_type | quote }}
url        = {{ $url | quote }}
executable = {{ dig "executable" false $gr }}
{{- if $checksum }}
["{{ $binName }}".checksum]
{{ $gr.checksum_type }} = {{ $checksum | quote }}
{{- end }}
{{- if eq $gr.external_type "archive-file" }}
{{-   $path := $gr.path_format | replace "{version}" $tool.version | replace "{target}" $target }}
path = {{ $path | quote }}
{{- end }}
{{- if hasKey $gr "strip_components" }}
strip_components = {{ $gr.strip_components }}
{{- end }}
