{{- define "external/release" -}}
{{- $key  := .key -}}
{{- $d    := .data -}}
{{- $root := .root -}}
{{- $base     := dig "github_releases" "base_url" "https://github.com" $root -}}
{{- $platform := printf "%s_%s" $root.chezmoi.os $root.chezmoi.arch -}}
{{- $target   := dig "platforms" $platform "" $d -}}
{{- if $target -}}
{{- $version  := $d.version -}}
{{- $tag      := $d.tag_format | replace "{version}" $version -}}
{{- $filename := $d.filename_format | replace "{version}" $version | replace "{tag}" $tag | replace "{target}" $target | replace "{os}" $root.chezmoi.os | replace "{arch}" $root.chezmoi.arch -}}
{{- $url := $d.url_format | replace "{base}" $base | replace "{repo}" $d.repo | replace "{version}" $version | replace "{tag}" $tag | replace "{filename}" $filename | replace "{target}" $target | replace "{os}" $root.chezmoi.os | replace "{arch}" $root.chezmoi.arch -}}
{{- $entry := dict "type" $d.external_type "url" $url -}}
{{- if dig "executable"       false $d -}}{{- $_ := set $entry "executable"      true -}}{{- end -}}
{{- if dig "readonly"         false $d -}}{{- $_ := set $entry "readonly"        true -}}{{- end -}}
{{- if dig "exact"            false $d -}}{{- $_ := set $entry "exact"           true -}}{{- end -}}
{{- if dig "strip_components" 0    $d -}}{{- $_ := set $entry "stripComponents" (dig "strip_components" 0 $d) -}}{{- end -}}
{{- if dig "include"          nil  $d -}}{{- $_ := set $entry "include"         (dig "include" list $d) -}}{{- end -}}
{{- if dig "path_format" "" $d -}}
  {{- $path := $d.path_format | replace "{version}" $version | replace "{tag}" $tag | replace "{target}" $target | replace "{os}" $root.chezmoi.os | replace "{arch}" $root.chezmoi.arch -}}
  {{- $_ := set $entry "path" $path -}}
{{- end -}}
{{- if dig "fallback_url_format" "" $d -}}
  {{- $fallback := $d.fallback_url_format | replace "{base}" $base | replace "{repo}" $d.repo | replace "{version}" $version | replace "{tag}" $tag | replace "{filename}" $filename | replace "{target}" $target | replace "{os}" $root.chezmoi.os | replace "{arch}" $root.chezmoi.arch -}}
  {{- $_ := set $entry "urls" (list $fallback) -}}
{{- end -}}
{{- $ctype := $d.checksum_type -}}
{{- if ne $ctype "none" -}}
  {{- $sha := dig "checksums" $platform "" $d -}}
  {{- if $sha -}}
    {{- $_ := set $entry "checksum" (dict $ctype $sha) -}}
  {{- else -}}
    {{- fail (printf "external/release: checksum_type=%q but no %s checksum for %s/%s" $ctype $ctype $key $platform) -}}
  {{- end -}}
{{- end -}}
{{- toToml (dict $key $entry) -}}
{{- end -}}
{{- end -}}

