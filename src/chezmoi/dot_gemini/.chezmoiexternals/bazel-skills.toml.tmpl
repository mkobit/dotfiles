{{- $workspace := output "git" "-C" .chezmoi.sourceDir "rev-parse" "--show-toplevel" | trim -}}
{{- if lookPath "bazel" -}}
{{- $_ := output "bash" "-c" (printf "cd %q && bazel build //src/ai/skills/..." $workspace) -}}
{{- end -}}
{{- $queryCmd := printf "cd %q && bazel cquery --output=files 'attr(tags, \"tool:gemini\", //src/ai/skills/...) except attr(tags, \"skip-install\", //src/ai/skills/...)' 2>/dev/null" $workspace -}}
{{- $queryOutput := output "bash" "-c" $queryCmd -}}
{{- range $line := splitList "\n" $queryOutput -}}
{{- $line = trim $line -}}
{{- if $line -}}
{{- if hasSuffix ".gemini.skill.tar" $line -}}
{{- $installName := base $line | trimSuffix ".gemini.skill.tar" -}}

["skills/{{ $installName }}"]
    type = "archive"
    url = "file://{{ $workspace }}/{{ $line }}"
    exact = true

{{ end -}}
{{- end -}}
{{- end -}}
