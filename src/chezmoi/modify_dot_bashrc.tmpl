#!/bin/sh
{{/* Enhanced sed compatibility for macOS BSD sed and Ubuntu GNU sed */}}
tempfile="$(mktemp)"
trap 'rm -rf "${tempfile}"' EXIT
cat > "${tempfile}"

# Remove existing chezmoi section if present
sed -i.bak '/.*modify_dot_bashrc\.tmpl:BEGIN:chezmoi:bash/,/.*modify_dot_bashrc\.tmpl:END:chezmoi:bash/d' "${tempfile}"

# Check if file ends with newline, if not add one
if [ -s "${tempfile}" ] && [ "$(tail -c1 "${tempfile}")" != "" ]; then
  echo >> "${tempfile}"
fi

# Add our managed section
cat >> "${tempfile}" << 'EOF'
# {{ .chezmoi.workingTree }}/{{ .chezmoi.sourceFile }}:BEGIN:chezmoi:bash:{{ include "modify_dot_bashrc.tmpl" | sha256sum | substr 0 8 }} - WARNING: managed by chezmoi, do not edit
source {{ .chezmoi.destDir }}/.dotfiles/bash/config.bash
# {{ .chezmoi.workingTree }}/{{ .chezmoi.sourceFile }}:END:chezmoi:bash:{{ include "modify_dot_bashrc.tmpl" | sha256sum | substr 0 8 }}
EOF

cat "${tempfile}"
