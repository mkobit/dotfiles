{{- /*
  Generates chezmoi external entries for bin tools whose BOM selects a download method.
  BOM: .local.bin.<name>.installation_method — set in .chezmoi.toml.tmpl.
  Default is "none"; each machine opts in via its config template.
  Tools with external_type "archive" (e.g. nvim) are handled via dot_local/.chezmoiexternals/.
*/ -}}
{{- $platform := printf "%s_%s" .chezmoi.os .chezmoi.arch -}}
{{- $base     := dig "github_releases" "base_url" "https://github.com" . -}}
{{- $localBin := dig "local" (dict) $ | dig "bin" (dict) -}}
{{- range $name, $tool := .bin -}}
{{-   $method := dig $name (dict) $localBin | dig "installation_method" "none" -}}
{{-   if eq $method "github_releases" -}}
{{-     if not (hasKey $tool "github_releases") -}}
{{-       fail (printf "bin.%s: installation_method is github_releases but no github_releases catalog entry exists" $name) -}}
{{-     end -}}
{{-     if eq $tool.github_releases.external_type "archive" -}}{{- /* skip: archive tools go in dot_local/.chezmoiexternals/ */ -}}
{{-     else -}}
{{-       if not (hasKey $tool.github_releases.platforms $platform) -}}
{{-         fail (printf "bin.%s: no github_releases platform entry for %s" $name $platform) -}}
{{-       end -}}
{{ includeTemplate "bin/github-releases-entry.tmpl" (dict "name" $name "tool" $tool "platform" $platform "base" $base) }}
{{-     end -}}
{{-   else if eq $method "direct_release" -}}
{{-     if not (hasKey $tool "direct_release") -}}
{{-       fail (printf "bin.%s: installation_method is direct_release but no direct_release catalog entry exists" $name) -}}
{{-     end -}}
{{-     if not (hasKey $tool.direct_release.platforms $platform) -}}
{{-       fail (printf "bin.%s: no direct_release platform entry for %s" $name $platform) -}}
{{-     end -}}
{{ includeTemplate "bin/direct-release-entry.tmpl" (dict "name" $name "tool" $tool "platform" $platform) }}
{{-   end -}}
{{- end -}}
