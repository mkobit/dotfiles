#!/usr/bin/env bash
set -euo pipefail

# Walks up from $PWD to find a .chezmoiroot file indicating a chezmoi source dir.
# When found and src/base/.git exists, outputs dual-repo git info for starship.
# Usage:
#   chezmoi-git-prompt          — output dual-repo status
#   chezmoi-git-prompt --check  — exit 0 if in chezmoi source dir, 1 otherwise

find_chezmoi_root() {
    local dir="$PWD"
    while [[ "$dir" != "/" ]]; do
        if [[ -f "$dir/.chezmoiroot" && -d "$dir/src/base/.git" ]]; then
            printf '%s' "$dir"
            return 0
        fi
        dir="$(dirname "$dir")"
    done
    return 1
}

if [[ "${1:-}" == "--check" ]]; then
    find_chezmoi_root >/dev/null 2>&1
    exit $?
fi

root="$(find_chezmoi_root)" || exit 0
base_root="$root/src/base"

o_branch="$(git -C "$root" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")"
b_branch="$(git -C "$base_root" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")"

o_status="✓"
if [[ -n "$(git -C "$root" status --porcelain 2>/dev/null | head -1)" ]]; then
    o_status="!"
fi

b_status="✓"
if [[ -n "$(git -C "$base_root" status --porcelain 2>/dev/null | head -1)" ]]; then
    b_status="!"
fi

printf 'chezmoi ovl:%s[%s] base:%s[%s]' "$o_branch" "$o_status" "$b_branch" "$b_status"
