{{- /*
  Generates chezmoi external entries for bin tools selected in the BOM.
  BOM: .local.bin.<name>.installation_method — set in .chezmoi.toml.tmpl.
  Default is "none" (all off); each machine opts in via its config template.

  Supported methods:
    github_releases  — download from GitHub releases via chezmoi externals
    homebrew         — managed by Brewfile; nothing to emit here
    apt              — managed by run_onchange_install-apt; nothing to emit here
    none             — skip
*/ -}}
{{- $platform := printf "%s_%s" .chezmoi.os .chezmoi.arch -}}
{{- $base     := dig "github_releases" "base_url" "https://github.com" . -}}
{{- range $name, $tool := .bin -}}
{{-   $method := dig $name (dict) $.local.bin | dig "installation_method" "none" -}}
{{-   if eq $method "github_releases" -}}
{{-     if not (hasKey $tool "github_releases") -}}
{{-       fail (printf "bin.%s: installation_method is github_releases but no github_releases catalog entry exists" $name) -}}
{{-     end -}}
{{-     if not (hasKey $tool.github_releases.platforms $platform) -}}
{{-       fail (printf "bin.%s: no github_releases platform entry for %s" $name $platform) -}}
{{-     end -}}
{{ includeTemplate "bin/github-releases-entry.tmpl" (dict "name" $name "tool" $tool "platform" $platform "base" $base) }}
{{-   else if eq $method "homebrew" -}}
{{-     /* managed by Brewfile — nothing to emit */ -}}
{{-   else if eq $method "apt" -}}
{{-     /* managed by apt installer — nothing to emit */ -}}
{{-   else if eq $method "none" -}}
{{-     /* explicitly disabled */ -}}
{{-   else -}}
{{-     fail (printf "bin.%s: unknown installation_method %q" $name $method) -}}
{{-   end -}}
{{- end -}}
