{{- if eq .local_bin_tools.jules.installation_method "dotfiles.uv" -}}
#!/usr/bin/env bash
# hash: {{ include (joinPath .chezmoi.workingTree "src/python/jules_cli/pyproject.toml") | sha256sum }}
set -euo pipefail

UV_TOOL_BIN_DIR="{{ .chezmoi.destDir }}/.local/bin/dotfiles" \
  mise exec --cd "{{ .chezmoi.workingTree }}" -- uv tool install --force --editable "{{ .chezmoi.workingTree }}/src/python/jules_cli"
{{- else }}
#!/usr/bin/env bash
set -euo pipefail

UV_TOOL_BIN_DIR="{{ .chezmoi.destDir }}/.local/bin/dotfiles" \
  mise exec --cd "{{ .chezmoi.workingTree }}" -- uv tool uninstall jules-cli 2>/dev/null || true
{{- end }}
