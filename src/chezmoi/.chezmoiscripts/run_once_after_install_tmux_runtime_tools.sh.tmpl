#!/bin/bash
# {{ template "managed_by_chezmoi.tmpl" . }}
# {{ includeTemplate "shell/utils.sh" . }}
# Hash of tool config to trigger updates: {{ include "dot_dotfiles/tmux/snippets/popups_enhanced.tmux.tmpl" | sha256sum }}

{{ if index . "python" "uv" -}}
if command -v uv >/dev/null 2>&1; then
    echo "Installing tmux-runtime-tools via uv tool..."
    uv tool install --force "{{ .chezmoi.sourceDir }}/../python/tmux-runtime-tools"
else
    echo "uv is not available but enabled. Skipping tmux-runtime-tools installation."
fi
{{- else -}}
echo "uv is disabled. Uninstalling tmux-runtime-tools if present..."
if command -v uv >/dev/null 2>&1; then
    uv tool uninstall tmux-runtime-tools >/dev/null 2>&1 || true
fi
rm -f "{{ .chezmoi.destDir }}/.local/bin/tmux-runtime-tools"
{{- end }}
