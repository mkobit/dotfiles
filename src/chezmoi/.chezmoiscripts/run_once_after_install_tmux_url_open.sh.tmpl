{{ if index . "python" "uv" }}#!/bin/bash
# {{ template "managed_by_chezmoi.tmpl" . }}
# {{ includeTemplate "shell/utils.sh" . }}
# Hash of tool config to trigger updates: {{ include "dot_dotfiles/tmux/snippets/popups_enhanced.tmux.tmpl" | sha256sum }}

if command -v uv >/dev/null 2>&1; then
    echo "Installing tmux-url-open via uv tool..."
    uv tool install --force "{{ .chezmoi.sourceDir }}/../python/tmux-url-open"
else
    echo "uv is not available but enabled. Skipping tmux-url-open installation."
fi
{{- else -}}#!/bin/bash
echo "uv is disabled. Uninstalling tmux-url-open if present..."
if command -v uv >/dev/null 2>&1; then
    uv tool uninstall tmux-url-open >/dev/null 2>&1 || true
fi
rm -f "${HOME}/.local/bin/tmux-url-open"
{{- end }}
