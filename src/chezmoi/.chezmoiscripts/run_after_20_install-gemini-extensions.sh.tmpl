{{- $geminiCli := index .mise.global_tools "npm:@google/gemini-cli" -}}
{{- if ne $geminiCli.installation "disabled" -}}
#!/usr/bin/env bash
{{/* Calculate hash from sorted JSON of extensions map for change detection in the script content itself */ -}}
{{- $extensionsJson := .gemini.extensions | default dict | toJson -}}
# gemini.extensions hash: {{ $extensionsJson | sha256sum }}

set -euo pipefail

# Source logging library from chezmoi source
CHEZMOI_SOURCE_DIR="{{ .chezmoi.sourceDir }}"
source "${CHEZMOI_SOURCE_DIR}/.chezmoitemplates/shell/logging.sh"

# Ensure gemini (via mise) is in PATH
export PATH="{{ .chezmoi.destDir }}/.local/bin:${PATH}"
eval "$(mise activate bash)"

log_info "Ensuring Gemini CLI extensions are installed..."

if ! command -v gemini &> /dev/null; then
    log_warn "gemini command not found in PATH. Skipping extension installation."
    exit 0
fi

GEMINI_BIN=$(mise which gemini || command -v gemini)
BUN_BIN=$(mise which bun || echo "")
RUN_CMD=("$GEMINI_BIN")
if [ -n "$BUN_BIN" ]; then
    RUN_CMD=("$BUN_BIN" "--bun" "$GEMINI_BIN")
fi

{{- range $name, $ext := .gemini.extensions }}
{{-   if eq $ext.installation "gemini-cli" }}
INSTALL_JSON="{{ $.chezmoi.destDir }}/.gemini/extensions/{{ $name }}/.gemini-extension-install.json"
if [[ -f "$INSTALL_JSON" ]] && grep -q '"ref": "{{ $ext.ref }}"' "$INSTALL_JSON"; then
    log_success "Extension {{ $name }} ({{ $ext.ref }}) already installed."
else
    log_info "Installing/Updating extension: {{ $name }} ({{ $ext.ref }})"
    # Uninstall first to prevent "already installed" errors during updates
    "${RUN_CMD[@]}" extensions uninstall "{{ $name }}" > /dev/null 2>&1 || true
    # We use --consent to bypass prompts.
    if ! "${RUN_CMD[@]}" extensions install "{{ $ext.url }}" --ref "{{ $ext.ref }}" --consent; then
        log_warn "Failed to install {{ $name }}. There may have been a network error."
    fi
fi
{{-   end }}
{{- end }}

log_success "Gemini extensions installation complete."
{{- end -}}
