package(default_visibility = ["//visibility:public"])

filegroup(
    name = "chezmoi_data",
    srcs = glob([
        ".chezmoidata/**/*.toml",
    ]) + [
        ".chezmoidata.toml",
    ],
)

# Committed skill copies (generated by //tools/agents:sync).
# Single-file skills exposed individually for diff_test.
exports_files(glob(["dot_*/skills/*/SKILL.md"]))

# Full skill directories exposed for upstream directory-level drift tests.
# One filegroup per upstream skill per tool.
[
    filegroup(
        name = "dot_%s_skill_creator_files" % tool,
        srcs = glob(["dot_%s/skills/skill-creator/**" % tool]),
    )
    for tool in [
        "claude",
        "cursor",
        "gemini",
    ]
]
